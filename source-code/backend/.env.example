# Sao chép file này thành .env và chỉnh giá trị phù hợp
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/library?schema=public" # Chuỗi kết nối PostgreSQL (user:pass@host:port/tên_db)
JWT_SECRET="doi-thanh-mot-chuoi-bi-mat-ngau-nhien-dai" # Khóa bí mật ký JWT (đổi thành chuỗi ngẫu nhiên dài ở production)
JWT_EXPIRES_IN="24h" # Thời hạn hiệu lực của token
PORT=4000 # Cổng chạy backend
CLIENT_ORIGIN="http://localhost:5173" # Origin frontend được phép gọi API (cho CORS)

# Tham số nghiệp vụ mặc định (có thể chỉnh trong bảng settings)
MAX_BOOKS_PER_USER=5 # Số sách tối đa mỗi người mượn cùng lúc
LOAN_DAYS=14 # Số ngày cho mượn mặc định
RENEW_DAYS=7 # Số ngày được gia hạn mỗi lần
MAX_RENEWALS=2 # Số lần gia hạn tối đa
FINE_PER_DAY=5000 # Phí phạt mỗi ngày trả trễ (đơn vị tiền)
