// Prisma schema — Hệ thống Quản lý Thư viện Mini
// Database: PostgreSQL

generator client {
  provider      = "prisma-client-js" // Loại client: JavaScript/Node
  // "native" cho môi trường dev (Windows/macOS/Linux), thêm target musl cho Docker Alpine
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"] // Build engine cho cả máy dev và container Alpine
}
// Kết thúc generator

datasource db {
  provider = "postgresql" // Hệ quản trị CSDL: PostgreSQL
  url      = env("DATABASE_URL") // Chuỗi kết nối lấy từ biến môi trường DATABASE_URL
}
// Kết thúc datasource

enum Role {
  STUDENT // Sinh viên (độc giả)
  LIBRARIAN // Thủ thư
  ADMIN // Quản trị viên
}
// Kết thúc enum Role

enum LoanStatus {
  PENDING // Chờ duyệt
  BORROWED // Đang mượn
  OVERDUE // Quá hạn
  RETURNED // Đã trả
  REJECTED // Bị từ chối
}
// Kết thúc enum LoanStatus

model User {
  id        Int      @id @default(autoincrement()) // Khóa chính, tự tăng
  fullName  String // Họ tên
  email     String   @unique // Email, không trùng
  password  String // Mật khẩu đã băm
  role      Role     @default(STUDENT) // Vai trò, mặc định sinh viên
  active    Boolean  @default(true) // Còn hoạt động (true) hay bị khóa (false)
  createdAt DateTime @default(now()) // Thời điểm tạo
  updatedAt DateTime @updatedAt // Tự cập nhật mỗi khi sửa bản ghi

  loans Loan[] // Quan hệ 1-nhiều: một user có nhiều phiếu mượn

  @@map("users") // Tên bảng thật trong DB là "users"
}
// Kết thúc model User

model Category {
  id        Int      @id @default(autoincrement()) // Khóa chính tự tăng
  name      String   @unique // Tên thể loại, không trùng
  createdAt DateTime @default(now()) // Thời điểm tạo

  books Book[] // Một thể loại có nhiều sách

  @@map("categories") // Tên bảng thật: "categories"
}
// Kết thúc model Category

model Author {
  id        Int      @id @default(autoincrement()) // Khóa chính tự tăng
  name      String // Tên tác giả
  bio       String? // Tiểu sử (có thể null)
  createdAt DateTime @default(now()) // Thời điểm tạo

  books Book[] // Một tác giả có nhiều sách

  @@map("authors") // Tên bảng thật: "authors"
}
// Kết thúc model Author

model Book {
  id              Int      @id @default(autoincrement()) // Khóa chính tự tăng
  title           String // Tiêu đề
  isbn            String?  @unique // Mã ISBN, không trùng (có thể null)
  description     String? // Mô tả
  publisher       String? // Nhà xuất bản
  publishedYear   Int? // Năm xuất bản
  coverUrl        String? // Đường dẫn ảnh bìa
  totalCopies     Int      @default(1) // Tổng số bản
  availableCopies Int      @default(1) // Số bản còn cho mượn
  categoryId      Int? // Khóa ngoại tới thể loại (có thể null)
  authorId        Int? // Khóa ngoại tới tác giả (có thể null)
  createdAt       DateTime @default(now()) // Thời điểm tạo
  updatedAt       DateTime @updatedAt // Tự cập nhật khi sửa

  category Category? @relation(fields: [categoryId], references: [id]) // Liên kết tới Category qua categoryId
  author   Author?   @relation(fields: [authorId], references: [id]) // Liên kết tới Author qua authorId
  loans    Loan[] // Một sách có nhiều phiếu mượn

  @@index([title]) // Đánh chỉ mục theo tiêu đề (tăng tốc tìm kiếm)
  @@index([categoryId]) // Đánh chỉ mục theo thể loại
  @@map("books") // Tên bảng thật: "books"
}
// Kết thúc model Book

model Loan {
  id           Int        @id @default(autoincrement()) // Khóa chính tự tăng
  bookId       Int // Khóa ngoại tới sách
  userId       Int // Khóa ngoại tới người mượn
  status       LoanStatus @default(PENDING) // Trạng thái phiếu, mặc định chờ duyệt
  requestedAt  DateTime   @default(now()) // Thời điểm gửi yêu cầu
  borrowedAt   DateTime? // Thời điểm bắt đầu mượn (sau khi duyệt)
  dueDate      DateTime? // Hạn phải trả
  returnedAt   DateTime? // Thời điểm đã trả
  renewalCount Int        @default(0) // Số lần đã gia hạn
  fineAmount   Int        @default(0) // Tiền phạt (nếu trả trễ)
  rejectReason String? // Lý do bị từ chối

  book Book @relation(fields: [bookId], references: [id]) // Liên kết tới sách qua bookId
  user User @relation(fields: [userId], references: [id]) // Liên kết tới người mượn qua userId

  renewals LoanRenewal[] // Một phiếu có nhiều lần gia hạn

  @@index([status]) // Chỉ mục theo trạng thái (lọc nhanh)
  @@index([userId]) // Chỉ mục theo người mượn
  @@map("loans") // Tên bảng thật: "loans"
}
// Kết thúc model Loan

model LoanRenewal {
  id         Int      @id @default(autoincrement()) // Khóa chính tự tăng
  loanId     Int // Khóa ngoại tới phiếu mượn
  oldDueDate DateTime // Hạn trả cũ (trước khi gia hạn)
  newDueDate DateTime // Hạn trả mới (sau khi gia hạn)
  renewedAt  DateTime @default(now()) // Thời điểm gia hạn

  loan Loan @relation(fields: [loanId], references: [id], onDelete: Cascade) // Liên kết tới phiếu; xóa phiếu thì xóa luôn lịch sử (Cascade)

  @@map("loan_renewals") // Tên bảng thật: "loan_renewals"
}
// Kết thúc model LoanRenewal

model Setting {
  key   String @id // Khóa cấu hình (vd max_books) làm khóa chính
  value String // Giá trị (lưu dạng chuỗi)

  @@map("settings") // Tên bảng thật: "settings"
}
// Kết thúc model Setting
